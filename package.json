{
  "name": "win32-mcp-inspector",
  "displayName": "Windows Automation Inspector (MCP)",
  "version": "2.5.1",
  "publisher": "RandyNorthrup",
  "description": "Enterprise-grade Windows automation MCP server with 53 tools — click_text, wait_for_text, structured OCR, UI Automation, and more",
  "categories": [
    "Other"
  ],
  "keywords": [
    "mcp",
    "windows",
    "automation",
    "screenshot",
    "ocr",
    "mouse",
    "keyboard",
    "window-management",
    "process-control",
    "clipboard",
    "ui-testing",
    "desktop-automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/RandyNorthrup/win32-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/RandyNorthrup/win32-mcp-server/issues"
  },
  "homepage": "https://github.com/RandyNorthrup/win32-mcp-server#readme",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "Windows MCP Inspector",
      "properties": {
        "win32-mcp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Windows Automation Inspector MCP server"
        },
        "win32-mcp.autoInstall": {
          "type": "boolean",
          "default": true,
          "description": "Automatically install win32-mcp-server Python package if not found"
        },
        "win32-mcp.tesseractPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to Tesseract OCR executable (leave empty to use PATH)"
        },
        "win32-mcp.ocrLanguage": {
          "type": "string",
          "default": "eng",
          "description": "Default OCR language (e.g. 'eng', 'fra', 'eng+fra')"
        },
        "win32-mcp.ocrPreprocess": {
          "type": "string",
          "enum": ["auto", "light_bg", "dark_bg", "high_contrast", "none"],
          "default": "auto",
          "description": "Default OCR preprocessing mode"
        },
        "win32-mcp.screenshotFormat": {
          "type": "string",
          "enum": ["png", "jpeg", "webp"],
          "default": "png",
          "description": "Default screenshot output format"
        },
        "win32-mcp.screenshotQuality": {
          "type": "number",
          "default": 85,
          "minimum": 1,
          "maximum": 100,
          "description": "JPEG/WebP quality (1-100)"
        },
        "win32-mcp.screenshotScale": {
          "type": "number",
          "default": 1.0,
          "minimum": 0.1,
          "maximum": 1.0,
          "description": "Screenshot scale factor (0.1-1.0)"
        },
        "win32-mcp.coordinateValidation": {
          "type": "boolean",
          "default": true,
          "description": "Validate click/move coordinates are within screen bounds"
        },
        "win32-mcp.debugLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose debug logging"
        }
      }
    }
  }
}
